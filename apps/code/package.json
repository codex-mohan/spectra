{
  "name": "@singularity-ai/spectra-code",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spectra Code — TUI coding agent with read, write, edit, and bash tools",
  "bin": {
    "spectra": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "chat:tui": "bun run src/cli.ts --interactive",
    "test": "vitest --run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.1.103",
    "@opentui/react": "^0.1.103",
    "@singularity-ai/spectra-agent": "^0.2.2",
    "@singularity-ai/spectra-ai": "^0.2.2",
    "@singularity-ai/spectra-app": "^0.2.2",
    "clipboardy": "^5.3.1",
    "dotenv": "^16.4.0",
    "react": "^19.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.2.0"
  },
  "license": "MIT"
}
