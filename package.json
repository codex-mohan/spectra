    "release": "changeset publish",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.5.0",
    "typedoc": "^0.28.19",
    "vitepress": "^1.6.4"
  }
}
