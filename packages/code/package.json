{
  "name": "@singularity-ai/spectra-code",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Spectra Code — TUI coding agent with CLI commands, tools, and LLM integration",
  "bin": {
    "spectra": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun src/cli.ts",
    "start": "bun src/cli.ts",
    "spectra:help": "tsx src/cli.ts --help",
    "test": "vitest --run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": ">=0.2.6",
    "@opentui/react": "^0.2.10",
    "@singularity-ai/spectra-agent": "workspace:*",
    "@singularity-ai/spectra-ai": "workspace:*",
    "react": "^19.2.6",
    "yargs": "^18.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "license": "MIT"
}
