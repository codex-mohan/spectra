{
  "name": "@mohanscodex/spectra-tui",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal terminal UI framework with differential rendering for flicker-free interactive CLI applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "tui",
    "terminal",
    "ui",
    "differential-rendering",
    "typescript",
    "cli"
  ],
  "dependencies": {
    "get-east-asian-width": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "license": "MIT"
}
